rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.token.email == 'yamexgilbs@gmail.com';
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && (isBootstrapAdmin() || getUserData().get('role', '') == role);
    }

    function isAdmin() {
      return isBootstrapAdmin() || (isSignedIn() && (getUserData().get('role', '') == 'Admin' || getUserData().get('role', '') == 'Pastor'));
    }

    function isStaff() {
      return isBootstrapAdmin() || (isSignedIn() && getUserData().get('role', '') in ['Admin', 'Pastor', 'Treasurer', 'Secretary', 'Department Leader']);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- Members Collection ---
    match /members/{memberId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // --- Finance Collection ---
    match /finance/{recordId} {
      allow read: if isStaff() || (isSignedIn() && resource.data.memberId == request.auth.uid);
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    // --- Expenses Collection ---
    match /expenses/{expenseId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // --- Prayer Requests ---
    match /prayerRequests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
                    && request.resource.data.memberId == request.auth.uid
                    && request.resource.data.requestText.size() < 5000;
      allow update: if isSignedIn() && resource.data.memberId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // --- Requisitions ---
    match /requisitions/{reqId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // --- Pledges ---
    match /pledges/{pledgeId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // --- Projects ---
    match /projects/{projectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Services ---
    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Finance Types ---
    match /financeTypes/{typeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Visitors ---
    match /visitors/{visitorId} {
      allow read, write: if isStaff();
    }

    // --- Broadcasts ---
    match /broadcasts/{broadcastId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Assets ---
    match /assets/{assetId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // --- Events ---
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // --- Attendance ---
    match /attendance/{atId} {
      allow read: if isSignedIn();
      allow write: if isStaff();
    }

    // --- Employees (HR) ---
    match /employees/{empId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // --- Payroll ---
    match /payroll/{payId} {
      allow read, write: if isAdmin();
    }

    // --- Admins (Role verification) ---
    match /admins/{adminId} {
      allow read: if isSignedIn();
    }

    // --- Departments ---
    match /departments/{deptId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

  }
}
